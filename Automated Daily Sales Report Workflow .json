    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    d.order_date AS report_date,\n    d.revenue,\n    d.orders,\n    p.revenue AS previous_day_revenue,\n\n    CASE \n        WHEN p.revenue IS NULL OR p.revenue = 0 THEN 0\n        ELSE ROUND((d.revenue - p.revenue) / p.revenue * 100, 2)\n    END AS revenue_change_percent,\n\n    (\n        SELECT GROUP_CONCAT(\n            CONCAT(product_name, ' - $', total_revenue)\n            ORDER BY total_revenue DESC\n            SEPARATOR '\\n'\n        )\n        FROM (\n            SELECT \n                product_name,\n                SUM(quantity * unit_price) AS total_revenue\n            FROM sales\n            WHERE order_date = d.order_date\n            GROUP BY product_name\n            ORDER BY total_revenue DESC\n            LIMIT 3\n        ) tp\n    ) AS top_3_products,\n\n    (SELECT MAX(order_id) FROM sales) AS latest_order_id\n\nFROM\n(\n    SELECT \n        order_date,\n        SUM(quantity * unit_price) AS revenue,\n        COUNT(*) AS orders\n    FROM sales\n    GROUP BY order_date\n    ORDER BY order_date DESC\n    LIMIT 1\n) d\n\nLEFT JOIN\n(\n    SELECT \n        order_date,\n        SUM(quantity * unit_price) AS revenue\n    FROM sales\n    GROUP BY order_date\n) p\nON p.order_date = DATE_SUB(d.order_date, INTERVAL 1 DAY)\n\nWHERE (SELECT MAX(order_id) FROM sales) >\n      (SELECT last_processed_order_id FROM sheet_tracking WHERE id = 1);",
        "options": {}
      },
