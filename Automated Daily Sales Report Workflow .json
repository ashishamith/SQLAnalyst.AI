      "parameters": {
        "sendTo": "ashishamithr@gmail.com",
        "subject": "Daily Sales Report",
        "message": "=<h2>📊 Daily Sales Report</h2>\n\n<p><b>Revenue:</b> ${{ $node[\"KPI\"].json[\"revenue\"] }}</p>\n\n<p><b>Change vs Previous Day:</b> \n<span style=\"color: {{ $node[\"KPI\"].json[\"revenue_change_percent\"] > 0 ? 'green' : 'red' }};\">\n{{ $node[\"KPI\"].json[\"revenue_change_percent\"] }}%\n</span>\n</p>\n\n<p><b>Total Orders:</b> {{ $node[\"KPI\"].json[\"orders\"] }}</p>\n\n<hr>\n\n<h3>Top Performing Products</h3>\n<pre>{{ $node[\"KPI\"].json[\"top_3_products\"] }}</pre>\n\n<hr>\n\n<h3>Executive Insight</h3>\n<p>{{ $node[\"Basic LLM Chain\"].json[\"text\"] }}</p>\n\n<hr>\n\n<p><i>Automated Executive Intelligence System</i></p>",
